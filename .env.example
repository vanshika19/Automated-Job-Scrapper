# Copy to `.env` and fill in. docker-compose picks these up automatically.
# Local CLI (`python -m job_scraper ...`) loads `.env` from the repo root on startup.

# --- Postgres -----------------------------------------------------------
POSTGRES_USER=jobs
POSTGRES_PASSWORD=jobs
POSTGRES_DB=jobs

# Used by the api + scraper containers. Defaults to the compose Postgres.
# To run against SQLite locally instead:  sqlite:////app/jobs.db
DATABASE_URL=postgresql+psycopg://jobs:jobs@db:5432/jobs

# --- Ports --------------------------------------------------------------
API_PORT=8000
WEB_PORT=8080

# --- CORS / frontend ----------------------------------------------------
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# --- Schema management --------------------------------------------------
# 0 = trust Alembic (recommended in compose). 1 = let SQLAlchemy create
# missing tables on engine boot (handy for local sqlite dev).
STORAGE_AUTO_CREATE=0

# --- AI matching --------------------------------------------------------
# Optional. If set, OpenAI embeddings (text-embedding-3-small) are used
# instead of the local sentence-transformers fallback.
OPENAI_API_KEY=

# --- LinkedIn (Apify) ---------------------------------------------------
# Required for LinkedIn actor runs (jobs + company posts).
# Create at https://console.apify.com/account/integrations
APIFY_TOKEN=
# Jobs actor: bebity~linkedin-jobs-scraper or console ID BHzefUZlZRKWxkTck
#APIFY_LINKEDIN_ACTOR=BHzefUZlZRKWxkTck
# Optional search knobs — comma or newline = multiple runs (cartesian product), merged + deduped.
#LINKEDIN_APIFY_TITLE=
#LINKEDIN_APIFY_LOCATION=
#LINKEDIN_APIFY_MAX_COMBINATIONS=20
#LINKEDIN_APIFY_TIMEOUT_SEC=300
#LINKEDIN_APIFY_PROXY_JSON=

# --- LinkedIn company posts (Apify) ------------------------------------
# Scrape company feed posts (not job listings). Console:
# https://console.apify.com/actors/A3cAPGpwBEG8RJwse/input
# Default URL list: config/linkedin_posts_targets.txt (repo root). Enable with either:
#LINKEDIN_POSTS_STANDALONE=1
# or point at any file (relative paths are from repo root):
#LINKEDIN_POSTS_TARGET_URLS_FILE=config/linkedin_posts_targets.txt
# Or comma/newline-separated URLs (overrides file when set):
#LINKEDIN_POSTS_TARGET_URLS=https://www.linkedin.com/company/foo/posts/
# Standalone list mode:  python -m job_scraper scrape --source linkedin_posts
# (Do not combine linkedin_posts with other --source values when using that list.)
#APIFY_LINKEDIN_POSTS_ACTOR=A3cAPGpwBEG8RJwse
#LINKEDIN_POSTS_APIFY_TIMEOUT_SEC=900
# Optional JSON merged with defaults; targetUrls is set per company from each URL above.
# Example: {"maxPosts":50,"postedLimit":"1months","scrapeComments":false}
#LINKEDIN_POSTS_APIFY_INPUT_JSON=

# --- Scraper tuning -----------------------------------------------------
SLEEP_PER_COMPANY=0.6

# Local environment files (use .env.example as the tracked template)
.env
.env.local
.env.*.local

# Python bytecode caches
__pycache__/
*.pyc
*.pyo

# Pytest / coverage caches
.pytest_cache/
.coverage

# Local workbook backups & run logs (keep registry source xlsx tracked)
*.bak.xlsx
*before*reverify*.xlsx
logs/

# Local SQLite database (use init-db / scrape to create)
jobs.db
